# Supabase project credentials (Dashboard → Project Settings → API)
# Copy URL / anon key to html/shared/config.js (browser cannot read .env directly)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Optional — build-time prerender (scripts/prerender-seo.mjs, Vercel build only)
# SITE_URL=https://renewal.chodrum.com
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# BO admin (Supabase Auth user with app_metadata.role=admin — see migration 014)
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=change-me
# ADMIN_ID=admin

# Kakao Login (REST API key → config.js; Secret → Edge Function secrets only)
KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
# KAKAO_OAUTH_MODE=bridge

# Naver Login (public Client ID → config.js; Secret → Edge Function secrets only)
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET
# NAVER_OAUTH_MODE=bridge

# Toss Payments (Client Key → config.js; Secret → Edge Function only)
# Leave TOSS_CLIENT_KEY empty until you sign up — FO uses demo checkout.
# TOSS_CLIENT_KEY=test_ck_YOUR_CLIENT_KEY
# TOSS_MODE=auto
# TOSS_SECRET_KEY=test_sk_YOUR_SECRET_KEY
# TOSS_CONFIRM_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/toss-confirm
# SHEET_DOWNLOAD_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/sheet-download
