# Supabase project credentials (Dashboard → Project Settings → API)
# Copy to html/shared/config.js (browser cannot read .env directly)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Optional — never put service_role in frontend HTML
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Kakao Login (REST API key → config.js; Secret → Edge Function secrets only)
KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
# KAKAO_OAUTH_MODE=bridge

# Naver Login (public Client ID → config.js; Secret → Edge Function secrets only)
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET
# NAVER_OAUTH_MODE=bridge
